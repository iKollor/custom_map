{
    "servers": {
        "shadcn": {
            "command": "npx",
            "args": [
                "-y",
                "shadcn@latest",
                "mcp"
            ]
        },
        "prisma": {
            "command": "npx",
            "args": [
                "prisma",
                "mcp"
            ]
        },
        "postgres": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-postgres",
                "postgresql://mapuser:map_dev@localhost:5432/mapdb"
            ]
        },
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "${workspaceFolder}"
            ]
        },
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp"
            ]
        }
    }
}